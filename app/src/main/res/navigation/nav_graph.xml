<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/loginFragment">

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.ubayadev.final_thekupangs_anmpc.view.LoginFragment"
        android:label="Login">

        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.ubayadev.final_thekupangs_anmpc.view.DashboardFragment"
        android:label="Dashboard">

        <action
            android:id="@+id/action_dashboard_to_addHabit"
            app:destination="@id/addHabitFragment" />
        <action
            android:id="@+id/action_dashboardFragment_to_editHabitFragment"
            app:destination="@id/editHabitFragment" />
    </fragment>

    <fragment
        android:id="@+id/addHabitFragment"
        android:name="com.ubayadev.final_thekupangs_anmpc.view.AddHabitFragment"
        android:label="Add Habit" >
        <action
            android:id="@+id/action_addHabitFragment_to_dashboardFragment"
            app:destination="@id/dashboardFragment"
            app:popUpToInclusive="true" />
    </fragment>
    <fragment
        android:id="@+id/editHabitFragment"
        android:name="com.ubayadev.final_thekupangs_anmpc.view.EditHabitFragment"
        android:label="EditHabitFragment" >
        <argument
            android:name="uuid"
            app:argType="integer" />
    </fragment>

</navigation>